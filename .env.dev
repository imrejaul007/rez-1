# rez-dev shared env — used by docker-compose.dev.yml
# Real secrets go to Render env groups; this file is for local dev only.

NODE_ENV=development

# Mongo + Redis (compose-level, internal to the network)
MONGO_ROOT_USER=rezadmin
MONGO_ROOT_PASS=rezdevpass
REDIS_PASSWORD=rezdevpass

# Cross-service secrets — must match across backend + auth-service
# SECURITY: regenerated 2026-06-21 from `crypto.randomBytes(48)` via Node REPL.
# Even for dev, these should not be predictable — the previous dev-...
# placeholder values would have been a real-world security hole if .env.dev
# ever leaked into a non-dev environment.
JWT_SECRET=oRyv5Wm49RkBUAQjNwKokCgOuRKXIoExXuIa5DaeJajgIE19iujYWIy5r/orDt7K
JWT_REFRESH_SECRET=uhe/eyF9Sf1hw1nETkqp6nKD57U7YTCZZwyyUp7GQ6N/0UeAu0C0iX3j49QntyuD
