# REZ API Gateway — Environment Variables
#
# SECURITY NOTE: This gateway handles authentication for all services.
# Ensure REDIS_PASSWORD is set for session storage authentication.
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32
# Copy to .env.local for local development. NEVER commit .env.local to git.
# For production/staging, set these in the Render dashboard.

# ── Core Service URLs ──────────────────────────────────────────────────────────
# Points to individual microservices. In production, these are onrender.com URLs.
# For local development, use localhost:PORT format.

# Monolith fallback (legacy support during strangler fig migration)
MONOLITH_URL=http://localhost:3000

# Backend core service
BACKEND_URL=http://localhost:3001

# ── Microservice URLs ──────────────────────────────────────────────────────────

# Auth service
AUTH_SERVICE_URL=http://localhost:3002

# Catalog service
CATALOG_SERVICE_URL=http://localhost:3003

# Gamification service
GAMIFICATION_SERVICE_URL=http://localhost:3004

# Analytics & Events service
ANALYTICS_SERVICE_URL=http://localhost:3009  # rez-analytics-events

# Wallet service
WALLET_SERVICE_URL=http://localhost:3011

# Payment service
PAYMENT_SERVICE_URL=http://localhost:3005

# Order service (BullMQ worker-based)
ORDER_SERVICE_URL=http://localhost:3006

# Search service
SEARCH_SERVICE_URL=http://localhost:3007

# Marketing service
MARKETING_SERVICE_URL=http://localhost:3013

# Media events service
MEDIA_SERVICE_URL=http://localhost:3008

# Notification events service
NOTIFICATION_SERVICE_URL=http://localhost:3012

# Merchant service
MERCHANT_SERVICE_URL=http://localhost:3020

# Finance service
FINANCE_SERVICE_URL=http://localhost:3010

# Ads service
ADS_SERVICE_URL=http://localhost:3014

# Karma service
KARMA_SERVICE_URL=http://localhost:3021

# ── CORS Origins ───────────────────────────────────────────────────────────────
# CRITICAL: Must be set for production deployments.
# Format: pipe-separated regex patterns for allowed origins.
# Examples:
#   Production: rez\.money|www\.rez\.money|menu\.rez\.money|admin\.rez\.money|merchant\.rez\.money|rez-app-admin\.vercel\.app|rez-app-consumer\.vercel\.app|rez-app-merchant\.vercel\.app|rez-web-menu\.vercel\.app|ad-bazaar\.vercel\.app
#   Development: localhost|127\.0\.0\.1
#
# SECURITY: Never include localhost origins in production!
# The nginx.conf uses these patterns in a regex match, so use proper regex escaping.
CORS_ORIGINS=localhost|127\.0\.0\.1

# ── Logging ────────────────────────────────────────────────────────────────────
NODE_ENV=development
