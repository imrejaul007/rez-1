{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node", "jest"],
    "moduleResolution": "node",
    "noImplicitAny": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@rez/shared": ["../packages/rez-shared/dist"],
      "@rez/shared/*": ["../packages/rez-shared/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__/**"]
}
