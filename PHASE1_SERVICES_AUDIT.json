{
  "auditDate": "2026-06-21",
  "authService": {
    "name": "rez-auth-service",
    "entry": "src/index.ts",
    "runtime": {
      "main": "dist/index.js",
      "dev": "ts-node src/index.ts",
      "engines": "node>=20"
    },
    "ports": {
      "http": "PORT (default 4002)",
      "health": "HEALTH_PORT (default 4102)"
    },
    "routerMounts": {
      "/api/v1/auth": "routes/authRoutes.ts (public + JWT)",
      "/api/v1/mfa": "routes/mfaRoutes.ts (JWT required)",
      "/api/v1/profile": "routes/profile.routes.ts (JWT required)",
      "/internal": "routes/internalRoutes.ts (internalToken required)",
      "/internal": "routes/internalProfile.routes.ts (internalToken required)",
      "/api/v1/oauth": "routes/oauthPartnerRoutes.ts (oauthLimiter)",
      "/api-docs": "swagger-ui",
      "/health": "inline (200 healthy/degraded, 503 if mongo down)",
      "/metrics": "inline (Prometheus)"
    },
    "endpoints": [
      { "method": "POST", "path": "/api/v1/auth/auth/otp/send", "auth": "rate-limit", "summary": "Send 6-digit OTP via SMS (default) or WhatsApp" },
      { "method": "POST", "path": "/api/v1/auth/auth/otp/send-whatsapp", "auth": "rate-limit", "summary": "Force WhatsApp channel" },
      { "method": "POST", "path": "/api/v1/auth/user/auth/send-otp", "auth": "rate-limit", "summary": "Legacy alias" },
      { "method": "POST", "path": "/api/v1/auth/auth/otp/verify", "auth": "rate-limit", "summary": "Verify OTP, issue access+refresh; if MFA enabled returns mfaRequired:true" },
      { "method": "POST", "path": "/api/v1/auth/user/auth/verify-otp", "auth": "rate-limit", "summary": "Legacy alias" },
      { "method": "POST", "path": "/api/v1/auth/auth/mfa/verify-otp", "auth": "rate-limit", "summary": "Complete login after MFA challenge (uses mfaSessionToken + totpCode)" },
      { "method": "POST", "path": "/api/v1/auth/auth/login-pin", "auth": "rate-limit", "summary": "4-6 digit PIN login; 5-fail/15-min lockout" },
      { "method": "POST", "path": "/api/v1/auth/user/auth/login-pin", "auth": "rate-limit", "summary": "Legacy alias" },
      { "method": "GET",  "path": "/api/v1/auth/auth/has-pin", "auth": "rate-limit", "summary": "Always {success:true} (anti-enumeration)" },
      { "method": "POST", "path": "/api/v1/auth/auth/set-pin", "auth": "JWT", "summary": "Set 4-6 digit PIN (rejects common PINs)" },
      { "method": "POST", "path": "/api/v1/auth/auth/complete-onboarding", "auth": "JWT", "summary": "Set profile/preferences + flip isOnboarded" },
      { "method": "PATCH","path": "/api/v1/auth/auth/profile", "auth": "JWT", "summary": "Update profile/preferences" },
      { "method": "DELETE","path": "/api/v1/auth/auth/account", "auth": "JWT", "summary": "Soft-delete + blacklist current token" },
      { "method": "GET",  "path": "/api/v1/auth/auth/me", "auth": "JWT", "summary": "Current user" },
      { "method": "GET",  "path": "/api/v1/auth/auth/validate", "auth": "rate-limit", "summary": "Returns {valid} publicly; full payload only with x-internal-token" },
      { "method": "POST", "path": "/api/v1/auth/auth/refresh", "auth": "rate-limit", "summary": "Rotate refresh -> new access+refresh" },
      { "method": "POST", "path": "/api/v1/auth/refresh-token", "auth": "rate-limit", "summary": "Legacy alias" },
      { "method": "POST", "path": "/api/v1/auth/auth/token/refresh", "auth": "rate-limit", "summary": "Same rotate handler" },
      { "method": "POST", "path": "/api/v1/auth/auth/logout", "auth": "JWT", "summary": "Blacklist access + refresh" },
      { "method": "POST", "path": "/api/v1/auth/auth/change-phone/request", "auth": "JWT+rate", "summary": "Send OTP to new number" },
      { "method": "POST", "path": "/api/v1/auth/auth/change-phone/verify", "auth": "JWT+rate", "summary": "Verify, atomic update, force re-login" },
      { "method": "POST", "path": "/api/v1/auth/auth/email/verify/request", "auth": "JWT+rate", "summary": "Send verification email (Resend)" },
      { "method": "GET",  "path": "/api/v1/auth/auth/email/verify/:token", "auth": "rate-limit", "summary": "Confirm from email link" },
      { "method": "POST", "path": "/api/v1/auth/auth/guest", "auth": "rate-limit", "summary": "Issue guest JWT (fail-closed store validation if MERCHANT_SERVICE_URL set)" },
      { "method": "POST", "path": "/api/v1/auth/auth/admin/login", "auth": "rate-limit", "summary": "Admin email+password; returns mfaRequired+pendingToken if admin MFA on" },
      { "method": "POST", "path": "/api/v1/auth/auth/admin/mfa/verify", "auth": "rate-limit", "summary": "TOTP or backup code for admin login" },
      { "method": "GET",  "path": "/api/v1/auth/internal/auth/user/:id", "auth": "internalToken", "summary": "Build user response by id" },
      { "method": "POST", "path": "/internal/users/patch-tests", "auth": "internalToken", "summary": "Record patch test (called by merchant-service)" },
      { "method": "GET",  "path": "/internal/users?phone=", "auth": "internalToken", "summary": "Lookup user by phone (audited)" },
      { "method": "POST", "path": "/internal/users/bulk", "auth": "internalToken", "summary": "Bulk lookup <=1000 ids" },
      { "method": "POST", "path": "/internal/users/:id/push-token", "auth": "internalToken", "summary": "Register/unregister push token" },
      { "method": "POST", "path": "/internal/profile/transaction", "auth": "internalToken", "summary": "Record cross-vertical tx" },
      { "method": "POST", "path": "/internal/profile/engagement", "auth": "internalToken", "summary": "Record engagement" },
      { "method": "GET",  "path": "/internal/profile/:userId?phone=", "auth": "internalToken", "summary": "Profile summary" },
      { "method": "POST", "path": "/internal/profile/refresh", "auth": "internalToken", "summary": "Batch refresh engagement scores" },
      { "method": "POST", "path": "/api/v1/mfa/auth/mfa/setup", "auth": "JWT", "summary": "TOTP secret + QR + 10 backup codes" },
      { "method": "POST", "path": "/api/v1/mfa/auth/mfa/verify-setup", "auth": "JWT", "summary": "Enable MFA after first TOTP verify" },
      { "method": "POST", "path": "/api/v1/mfa/auth/mfa/verify", "auth": "JWT", "summary": "Verify TOTP during authed flow" },
      { "method": "POST", "path": "/api/v1/mfa/auth/mfa/backup-verify", "auth": "JWT", "summary": "Verify XXXX-XXXX backup code" },
      { "method": "DELETE","path": "/api/v1/mfa/auth/mfa/disable", "auth": "JWT", "summary": "Disable MFA (requires TOTP)" },
      { "method": "GET",  "path": "/api/v1/mfa/auth/mfa/status", "auth": "JWT", "summary": "MFA status + backup-code count" },
      { "method": "GET",  "path": "/api/v1/profile/summary", "auth": "JWT", "summary": "Unified cross-vertical profile" },
      { "method": "POST", "path": "/api/v1/profile/transaction", "auth": "JWT", "summary": "Record tx" },
      { "method": "POST", "path": "/api/v1/profile/engagement", "auth": "JWT", "summary": "Record engagement" },
      { "method": "GET",  "path": "/api/v1/profile/tier", "auth": "JWT", "summary": "Tier + LTV + next threshold" },
      { "method": "GET",  "path": "/api/v1/oauth/authorize", "auth": "oauthLimiter", "summary": "Returns authorization_url + state" },
      { "method": "POST", "path": "/api/v1/oauth/consent", "auth": "oauthLimiter", "summary": "OTP-verify + auth code" },
      { "method": "POST", "path": "/api/v1/oauth/token", "auth": "oauthLimiter", "summary": "authorization_code -> access (1h) + refresh (30d)" },
      { "method": "GET",  "path": "/api/v1/oauth/userinfo", "auth": "Bearer", "summary": "OIDC userinfo" },
      { "method": "POST", "path": "/api/v1/oauth/refresh", "auth": "clientSecret", "summary": "refresh_token with rotation + reuse detection" },
      { "method": "POST", "path": "/api/v1/oauth/revoke", "auth": "clientSecret", "summary": "Revoke token" }
    ],
    "endpointCount": 47,
    "authFlows": [
      "Phone OTP (SMS/WhatsApp) -> JWT",
      "PIN login (4-6 digit, 5-fail/15-min lock)",
      "MFA / TOTP (RFC 6238, 30s window, ±1 skew, base32 secret, AES-256-GCM at rest)",
      "Backup codes (XXXX-XXXX)",
      "JWT access (15m default) + refresh (24h default, max 48h) with single-use rotation",
      "Token validation endpoint /auth/validate for sibling services",
      "Refresh token rotation with Redis SET NX + Mongo RefreshToken unique index + 409 on concurrent reuse",
      "Logout blacklists both access + refresh (Redis + Mongo lastLogoutAt fallback)",
      "OAuth2 partner flow (authorization_code + refresh rotation + reuse detection + revoke)",
      "Email verification via Resend (24h token TTL)",
      "Phone change two-step with atomic update + forced re-login",
      "Guest session with optional storeId validation (fail-closed if MERCHANT_SERVICE_URL set)",
      "Admin login (bcrypt + 5-fail lock + AdminMfaConfig challenge)",
      "Device fingerprint (UA+lang+IP sha256, 16 hex) with risk levels trusted|new|suspicious",
      "Inter-service internal API via x-internal-token + x-internal-service scoped by INTERNAL_SERVICE_TOKENS_JSON"
    ],
    "requiredEnvVars": [
      "MONGODB_URI",
      "REDIS_URL",
      "JWT_SECRET",
      "JWT_REFRESH_SECRET",
      "JWT_ADMIN_SECRET",
      "JWT_MERCHANT_SECRET",
      "OTP_HMAC_SECRET",
      "INTERNAL_SERVICE_TOKENS_JSON or INTERNAL_SERVICE_TOKEN"
    ],
    "effectivelyRequiredEnvVars": [
      "PORT", "HEALTH_PORT", "CORS_ORIGIN",
      "RESEND_API_KEY", "RESEND_FROM_EMAIL", "APP_URL",
      "OTP_TOTP_ENCRYPTION_KEY",
      "MERCHANT_SERVICE_URL (for guest auth with storeId)",
      "PARTNER_RENDEZ_CLIENT_SECRET", "PARTNER_STAY_OWEN_CLIENT_SECRET", "PARTNER_ADBAZAAR_CLIENT_SECRET"
    ],
    "optionalEnvVars": [
      "JWT_REFRESH_TTL_HOURS (24, max 48)",
      "JWT_EXPIRES_IN (15m)",
      "JWT_ADMIN_EXPIRES_IN (15m)",
      "JWT_MFA_SESSION_SECRET (fallback JWT_SECRET)",
      "SENTRY_DSN", "SENTRY_TRACES_SAMPLE_RATE",
      "OTEL_SERVICE_NAME", "OTEL_EXPORTER_OTLP_ENDPOINT",
      "ALLOWED_INTERNAL_IPS (fatal in production if unset)",
      "MFA_REQUIRED_FOR_ROLE",
      "EXPOSE_DEV_OTP (never in production)"
    ],
    "jwtShape": {
      "accessToken": {
        "algorithm": "HS256",
        "claims": ["userId", "role", "iat", "exp", "phoneNumber?", "merchantId?"],
        "secretByRole": {
          "admin|operator|support|super_admin": "JWT_ADMIN_SECRET",
          "merchant": "JWT_MERCHANT_SECRET",
          "default": "JWT_SECRET"
        },
        "expiryByRole": {
          "admin": "JWT_ADMIN_EXPIRES_IN ?? JWT_EXPIRES_IN ?? 15m",
          "merchant": "24h",
          "default": "JWT_EXPIRES_IN ?? 15m"
        }
      },
      "refreshToken": {
        "algorithm": "HS256",
        "claims": ["userId", "role", "type:refresh", "iat", "exp"],
        "secret": "JWT_REFRESH_SECRET",
        "expiry": "JWT_REFRESH_TTL_HOURS hours (default 24, max 48)"
      },
      "mfaSessionToken": {
        "ttl": "5m",
        "claims": ["userId", "phone", "role", "deviceFingerprint", "purpose:mfa_verify"],
        "secret": "JWT_MFA_SESSION_SECRET ?? JWT_SECRET"
      },
      "adminPendingToken": {
        "ttl": "5m",
        "claims": ["userId", "role", "email", "mfaPending:true", "pendingSince"],
        "secret": "JWT_ADMIN_SECRET"
      }
    },
    "interServiceAuth": {
      "mechanism": "x-internal-token header (with optional x-internal-service for scoped lookup)",
      "scoped": "INTERNAL_SERVICE_TOKENS_JSON (object: {serviceName: token}); lookup is constant-time",
      "legacy": "INTERNAL_SERVICE_TOKEN (single shared secret fallback)",
      "ipAllowlist": "ALLOWED_INTERNAL_IPS (comma-separated CIDR/IP); in production empty -> reject all",
      "outboundFromAuth": "fetch(MERCHANT_SERVICE_URL/api/internal/stores/:id/validate) with x-internal-token: INTERNAL_SERVICE_TOKEN (no scoping here)",
      "note": "Nginx gateway actively strips X-Internal-Token / X-Internal-Service from inbound public requests to prevent spoofing"
    },
    "otpDelivery": {
      "packageJson": "no twilio dependency; resend + bullmq present",
      "sms": "BullMQ 'notification-events' queue with eventType 'otp_sms' -> consumed by notification-service",
      "whatsapp": "BullMQ 'notification-events' queue with eventType 'otp_whatsapp'",
      "verify": "Hashed via HMAC-SHA256(OTP_HMAC_SECRET, phone+otp) and stored in Redis; atomic GET/CMP/DEL via Lua",
      "email": "Resend directly (no queue)"
    },
    "notes": [
      "routes/admin/oauthAdmin.ts is NOT mounted in index.ts (dead code)",
      "Auth service exposes bare-path aliases (e.g. /send-otp) AND /user/auth/* aliases inside /api/v1/auth router for gateway-strip compatibility",
      "/auth/validate returns full payload (userId, role, merchantId) only when x-internal-token matches INTERNAL_SERVICE_TOKEN; public callers get {valid:true} only (BAK-AUTH-002)"
    ]
  },
  "gateway": {
    "name": "rez-api-gateway",
    "importantContext": "Dockerfile is FROM nginx:1.27-alpine. The deployed container is nginx with envsubst. The Node src/index.ts is reference only and NOT used at runtime.",
    "runtime": {
      "container": "nginx 1.27 alpine",
      "entrypoint": "start.sh -> envsubst on nginx.conf.template -> exec nginx",
      "engines": "node>=20 (used only in src reference)"
    },
    "ports": {
      "http": "PORT (default 10000 on Render)"
    },
    "routingMechanism": {
      "primary": "nginx with location blocks + proxy_pass + envsubst-substituted service URLs",
      "alternative": "Kong declarative config (kong/declarative/kong.yml) NOT used at runtime",
      "node": "src/index.ts is reference only; does NOT proxy /api/auth to auth service"
    },
    "pathRewriting": [
      {
        "gatewayPath": "/api/auth",
        "rewrite": "rewrite ^/api/auth(/.*)?$ $1 break;  # strips /api/auth",
        "upstream": "$auth_backend = ${AUTH_SERVICE_URL}",
        "note": "BREAKS: auth service mounts at /api/v1/auth, not /auth. Until fixed, only /api/user/auth/* works."
      },
      {
        "gatewayPath": "/api/user/auth",
        "rewrite": "rewrite ^/api/user/auth(/.*)?$ $1 break;  # strips /api/user/auth",
        "upstream": "$auth_backend = ${AUTH_SERVICE_URL}",
        "note": "WORKS: auth service has matching /user/auth/* aliases"
      }
    ],
    "requiredEnvVars": [
      "PORT (default 10000)",
      "MONOLITH_URL",
      "SEARCH_SERVICE_URL",
      "AUTH_SERVICE_URL",
      "PAYMENT_SERVICE_URL",
      "WALLET_SERVICE_URL",
      "MERCHANT_SERVICE_URL",
      "CATALOG_SERVICE_URL",
      "MARKETING_SERVICE_URL",
      "ORDER_SERVICE_URL",
      "ANALYTICS_SERVICE_URL",
      "GAMIFICATION_SERVICE_URL",
      "MEDIA_SERVICE_URL",
      "FINANCE_SERVICE_URL",
      "ADS_SERVICE_URL",
      "NOTIFICATION_SERVICE_URL (envsubst only, not fail-fast)",
      "KARMA_SERVICE_URL (envsubst only, not fail-fast)"
    ],
    "failFastList": [
      "MONOLITH_URL", "SEARCH_SERVICE_URL", "AUTH_SERVICE_URL", "PAYMENT_SERVICE_URL",
      "WALLET_SERVICE_URL", "MERCHANT_SERVICE_URL", "CATALOG_SERVICE_URL",
      "MARKETING_SERVICE_URL", "ORDER_SERVICE_URL", "ANALYTICS_SERVICE_URL",
      "GAMIFICATION_SERVICE_URL", "MEDIA_SERVICE_URL", "FINANCE_SERVICE_URL", "ADS_SERVICE_URL"
    ],
    "healthEndpoints": [
      { "path": "/status", "method": "GET", "auth": "none", "response": "200 {status:ok,service:rez-api-gateway,timestamp}" },
      { "path": "/health", "method": "GET", "auth": "none", "response": "same as /status, backward-compat alias" },
      { "path": "/health/services", "method": "GET", "auth": "ip-restricted (10.0.0.0/8, 127.0.0.1/32)", "response": "200 with upstream URL map" }
    ],
    "corsAllowlist": [
      "https://rez.money", "https://www.rez.money", "https://menu.rez.money",
      "https://admin.rez.money", "https://merchant.rez.money",
      "https://rez-app-admin.vercel.app", "https://rez-app-consumer.vercel.app",
      "https://rez-app-marchant.vercel.app (sic, typo in source)",
      "https://rez-web-menu.vercel.app", "https://ad-bazaar.vercel.app"
    ],
    "tokenValidation": "NONE. The gateway is a pure router. JWT validation happens inside each downstream service.",
    "securityHeaders": "Adds CSP, X-Frame-Options DENY, X-Content-Type-Options nosniff, Referrer-Policy, Permissions-Policy; strips X-Internal-Token and X-Internal-Service from inbound public requests"
  },
  "frontendWiring": [
    { "frontendPath": "/api/user/auth/send-otp", "method": "POST", "gatewayPath": "/api/user/auth/send-otp", "authServicePath": "/api/v1/auth/user/auth/send-otp", "body": "{phone, countryCode?, channel?, force?}", "response": "{success, isNewUser, hasPIN, message}" },
    { "frontendPath": "/api/user/auth/verify-otp", "method": "POST", "gatewayPath": "/api/user/auth/verify-otp", "authServicePath": "/api/v1/auth/user/auth/verify-otp", "body": "{phone, otp, countryCode?}", "response": "{success, isNewUser, accessToken, refreshToken, tokens:{accessToken, refreshToken, expiresIn}, user, deviceRisk} OR {success, mfaRequired:true, mfaSessionToken, backupCodesAvailable}" },
    { "frontendPath": "/api/user/auth/mfa/verify-otp", "method": "POST", "gatewayPath": "/api/user/auth/mfa/verify-otp", "authServicePath": "/api/v1/auth/user/auth/mfa/verify-otp (NOT ALIASED - will 404)", "body": "{mfaSessionToken, totpCode}", "response": "DOES NOT WORK - need new gateway route or new alias in auth service" },
    { "frontendPath": "/api/user/auth/login-pin", "method": "POST", "gatewayPath": "/api/user/auth/login-pin", "authServicePath": "/api/v1/auth/user/auth/login-pin", "body": "{phone, countryCode?, pin}", "response": "{success, accessToken, refreshToken, tokens, user, deviceRisk}" },
    { "frontendPath": "/api/user/auth/logout", "method": "POST", "gatewayPath": "/api/user/auth/logout", "authServicePath": "/api/v1/auth/user/auth/logout", "body": "{refreshToken?}", "response": "{success:true}", "note": "Send refreshToken in body to also blacklist it" },
    { "frontendPath": "/api/user/auth/me", "method": "GET", "gatewayPath": "/api/user/auth/me", "authServicePath": "/api/v1/auth/user/auth/me", "body": null, "response": "{success, data:{id,name,phone,email,role,isVerified,isOnboarded,profile}}" },
    { "frontendPath": "/api/user/auth/refresh-token", "method": "POST", "gatewayPath": "/api/user/auth/refresh-token", "authServicePath": "/api/v1/auth/user/auth/refresh-token", "body": "{refreshToken}", "response": "{success, accessToken, refreshToken, expiresIn}" },
    { "frontendPath": "/api/user/auth/profile", "method": "PATCH", "gatewayPath": "/api/user/auth/profile", "authServicePath": "/api/v1/auth/user/auth/profile", "body": "{profile?, preferences?}", "response": "{success, data:user}" },
    { "frontendPath": "/api/user/auth/complete-onboarding", "method": "POST", "gatewayPath": "/api/user/auth/complete-onboarding", "authServicePath": "/api/v1/auth/user/auth/complete-onboarding", "body": "{profile?, preferences?}", "response": "{success, data, message}" },
    { "frontendPath": "/api/user/auth/account", "method": "DELETE", "gatewayPath": "/api/user/auth/account", "authServicePath": "/api/v1/auth/user/auth/account", "body": null, "response": "{success, message}" }
  ],
  "redFlags": [
    "/api/auth/... rewrite is broken (strips /api/auth but auth service mounts at /api/v1/auth) - use /api/user/auth/... until fixed",
    "/api/v1/mfa/... (post-login MFA setup) is NOT routed by the gateway",
    "/api/v1/oauth/... (partner OAuth) is NOT routed by the gateway",
    "/internal/* is NOT routed by the gateway (intentional - direct service-to-service)",
    "CORS allowlist does not include localhost dev ports; need a Vercel preview deployment to test",
    "nginx strips X-Internal-Token/X-Internal-Service from inbound requests - so /auth/validate is the only safe way for sibling services to introspect a token",
    "MFA verify-otp path after OTP-verify (the /auth/mfa/verify-otp route) is not reachable via the gateway; needs either a new gateway route or a new alias",
    "OTP delivery uses BullMQ -> notification-service, NOT twilio (twilio is NOT a dep of this auth service)"
  ]
}
