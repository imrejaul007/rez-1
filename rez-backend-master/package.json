{
  "name": "user-backend",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "node scripts/tsc-build.js",
    "lint": "eslint src --ext .ts",
    "db:indexes": "ts-node -r tsconfig-paths/register src/scripts/ensureIndexes.ts",
    "indexes:sync": "ts-node scripts/syncIndexes.ts",
    "start": "node --max-old-space-size=4096 --optimize-for-size dist/server.js",
    "start:worker": "node --max-old-space-size=4096 --optimize-for-size dist/worker.js",
    "test": "node --max-old-space-size=4096 ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__/services",
    "test:integration": "jest --testPathPattern=__tests__/routes",
    "test:e2e": "jest --testPathPattern=__tests__/e2e",
    "test:e2e-merchant": "node tests/e2e/merchant-endpoints-test.js",
    "seed": "ts-node src/scripts/seedDatabase.ts",
    "seed:categories": "ts-node src/scripts/checkAndSeedCategories.ts",
    "migrate:discounts": "ts-node src/scripts/migrateDiscounts.ts",
    "seed:all": "node scripts/seed-all-quick.js",
    "seed:quick": "node scripts/seed-all-quick.js",
    "seed:simple": "ts-node src/scripts/seedSimple.ts",
    "seed:carts": "ts-node src/scripts/seedCarts.ts",
    "seed:orders": "ts-node src/scripts/seedOrders.ts",
    "seed:videos": "ts-node src/scripts/seedVideos.ts",
    "seed:ugc-videos": "ts-node src/scripts/seedUGCVideos.ts",
    "seed:reviews": "ts-node src/scripts/seedReviews.ts",
    "seed:financial-services": "ts-node src/seeds/financialServicesSeeds.ts",
    "verify:financial-services": "ts-node src/scripts/verifyFinancialServices.ts",
    "seed:wishlists": "ts-node src/scripts/seedWishlists.ts",
    "seed:notifications": "ts-node src/scripts/seedNotifications.ts",
    "seed:coupons": "ts-node src/scripts/seedCoupons.ts",
    "seed:user-settings": "ts-node src/scripts/seedUserSettings.ts",
    "seed:cashback": "ts-node src/scripts/seedCashback.ts",
    "seed:everything": "ts-node src/scripts/seedAllModels.ts",
    "seed:product-fields": "ts-node scripts/seed-product-fields.ts",
    "test:product-integration": "ts-node scripts/test-product-integration.ts",
    "seed:prod": "node dist/scripts/seedDatabase.js",
    "check:store-mappings": "ts-node src/scripts/checkStoreMappings.ts",
    "reset:merchant-passwords": "ts-node src/scripts/resetMerchantPasswords.ts",
    "check:product-links": "ts-node src/scripts/checkAndFixProductLinks.ts",
    "migrate:product-images": "ts-node src/scripts/migrateProductImages.ts",
    "migrate:store-logos": "ts-node src/scripts/migrateStoreLogos.ts",
    "sync:all": "ts-node src/scripts/syncMerchantUserData.ts all",
    "sync:merchants": "ts-node src/scripts/syncMerchantUserData.ts merchants",
    "sync:products": "ts-node src/scripts/syncMerchantUserData.ts products",
    "sync:status": "ts-node src/scripts/syncMerchantUserData.ts status",
    "seed:trials": "ts-node src/scripts/seedTrials.ts",
    "seed:events": "ts-node src/scripts/seedEvents.ts",
    "seed:subscriptions": "ts-node scripts/seedSubscriptions.ts",
    "seed:subscription-tiers": "ts-node src/scripts/seedSubscriptionTiers.ts",
    "seed:referrals": "ts-node scripts/seedReferrals.ts",
    "seed:gamification": "ts-node scripts/seedGamification.ts",
    "seed:more-users": "ts-node scripts/seedMoreUsers.ts",
    "seed:critical": "ts-node scripts/seedCriticalData.ts",
    "seed:vouchers": "ts-node src/scripts/seedVouchersWithStores.ts",
    "verify:voucher-stores": "ts-node src/scripts/verifyAndLinkVoucherStores.ts",
    "test:events": "node scripts/test-event-system.js",
    "test:new-arrivals": "node scripts/test-new-arrivals.js",
    "seed:challenges": "ts-node src/scripts/seedChallenges.ts",
    "seed:mall-brands": "ts-node src/scripts/seedMallBrands.ts",
    "seed:creators": "ts-node src/scripts/seed-user-creators.ts",
    "seed:payment-methods": "ts-node scripts/update-store-payment-methods.ts",
    "seed:bnpl-stores": "ts-node scripts/seed-store-bnpl.ts",
    "seed:search-history": "ts-node scripts/seed-search-history.ts",
    "seed:nearby-activity": "ts-node scripts/seed-nearby-activity.ts",
    "seed:discovery": "npm run seed:payment-methods && npm run seed:bnpl-stores && npm run seed:search-history && npm run seed:nearby-activity",
    "seed:offers-page": "ts-node src/scripts/seedOffersPage.ts",
    "seed:homepage": "ts-node src/seeds/homepageSeeds.ts",
    "seed:homepage-deals": "ts-node src/seeds/homepageDealsSeeds.ts",
    "seed:master": "ts-node src/seeds/masterSeeds.ts",
    "seed:offers-page:clear": "ts-node src/scripts/seedOffersPage.ts --clear",
    "seed:category-page": "ts-node src/scripts/seedCategoryPageData.ts",
    "seed:category-page:clear": "ts-node src/scripts/seedCategoryPageData.ts --clear",
    "seed:home-services": "ts-node src/scripts/seedHomeServices.ts",
    "seed:home-services:clear": "ts-node src/scripts/seedHomeServices.ts --clear",
    "validate:discovery": "ts-node scripts/validate-discovery-data.ts",
    "load:basic": "artillery run artillery-tests/basic-load.yml --output reports/basic-load.json",
    "load:spike": "artillery run artillery-tests/spike-test.yml --output reports/spike-test.json",
    "load:stress": "artillery run artillery-tests/stress-test.yml --output reports/stress-test.json",
    "load:endurance": "artillery run artillery-tests/endurance-test.yml --output reports/endurance-test.json",
    "load:report": "artillery report reports/basic-load.json --output reports/basic-load.html",
    "profile:cpu": "clinic doctor -- node dist/server.js",
    "profile:memory": "clinic heapprofiler -- node dist/server.js",
    "profile:eventloop": "clinic bubbleprof -- node dist/server.js",
    "start:prod": "node --max-old-space-size=4096 --optimize-for-size dist/server.js",
    "start:prod:gc": "node --max-old-space-size=4096 --optimize-for-size --expose-gc dist/server.js",
    "migrate": "ts-node scripts/migrate.ts",
    "migrate:rollback": "ts-node scripts/migrate.ts rollback",
    "docker:build": "docker build -t rezapp/merchant-backend:latest .",
    "docker:push": "docker push rezapp/merchant-backend:latest",
    "k8s:deploy": "kubectl apply -f k8s/ -n production",
    "k8s:status": "kubectl rollout status deployment/merchant-backend -n production",
    "k8s:logs": "kubectl logs -f deployment/merchant-backend -n production",
    "health": "bash scripts/health-check.sh",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "perf:bench": "ts-node -r tsconfig-paths/register src/scripts/perfBench.ts",
    "prepare": "true",
    "format": "prettier --write 'src/**/*.ts'",
    "load-test": "ts-node scripts/loadTest.ts",
    "backup:verify": "ts-node src/scripts/verifyBackup.ts",
    "backup:test-restore": "ts-node src/scripts/testRestore.ts"
  },
  "keywords": [],
